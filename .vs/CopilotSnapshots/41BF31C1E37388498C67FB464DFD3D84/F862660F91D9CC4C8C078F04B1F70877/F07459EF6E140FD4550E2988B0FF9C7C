namespace ServiceCenterService.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    //[Authorize]
    public class ServiceCenterController : ControllerBase
    {
        ServiceCenterContext _context;

        public ServiceCenterController(ServiceCenterContext context)
        {
            _context = context;
        }


        [HttpGet]
        public IActionResult Get()
        {
            try
            {
                var centers = _context.ServiceCenters.ToList();

                if (centers == null || centers.Count == 0)
                    return NotFound("No service centers available.");

                return Ok(centers);
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}");
            }
        }




        [HttpGet("{id}")]
        public IActionResult Get(int id)
        {
            try
            {
                var center = _context.ServiceCenters.Find(id);
                if (center != null)
                {
                    return center;
                }
            }
            catch () {
            
            }

        }




