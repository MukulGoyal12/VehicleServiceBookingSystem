namespace ServiceCenterService.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    //[Authorize]
    public class ServiceCenterController : ControllerBase
    {
        ServiceCenterContext _context;

        public ServiceCenterController(ServiceCenterContext context)
        {
            _context = context;
        }


        [HttpGet]
        public IActionResult Get()
        {
            try
            {
                var centers = _context.ServiceCenters.ToList();

                if (centers == null || centers.Count == 0)
                    return NotFound("No service centers available.");

                return Ok(centers);
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}");
            }
        }




        [HttpGet("{id}")]
        public async Task<IActionResult> Get(int id)
        {
            try
            {
                var serviceCenter = await _context.ServiceCenters.FindAsync(id);
                if (serviceCenter == null)
                    return NotFound();
                return Ok(serviceCenter);
            }
            catch (Microsoft.Data.SqlClient.SqlException)
            {
                return StatusCode(500, "Database error while retrieving the service center.");
            }
            catch (Exception)
            {
                return StatusCode(500, "An unexpected error occurred.");
            }
        }




